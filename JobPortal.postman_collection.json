{
  "info": {
    "name": "Secure Job Portal API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Comprehensive Postman collection for testing the Secure Job Portal Platform endpoints."
  },
  "item": [
    {
      "name": "Authentication & Profile",
      "item": [
        {
          "name": "Register Candidate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Alice Candidate\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"Password123!\",\n  \"confirm_password\": \"Password123!\",\n  \"role\": \"Candidate\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/register",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "register"]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.environment.set(\"TOKEN\", jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"candidate@jobportal.com\",\n  \"password\": \"CandidatePassword123!\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/auth/login",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/auth/profile",
              "host": ["{{BASE_URL}}"],
              "path": ["auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Jobs Board",
      "item": [
        {
          "name": "Browse Jobs (Open)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{BASE_URL}}/jobs?search=devops&location=remote&employment_type=Remote",
              "host": ["{{BASE_URL}}"],
              "path": ["jobs"],
              "query": [
                {
                  "key": "search",
                  "value": "devops"
                },
                {
                  "key": "location",
                  "value": "remote"
                },
                {
                  "key": "employment_type",
                  "value": "Remote"
                }
              ]
            }
          }
        },
        {
          "name": "Create Job posting (Recruiter)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior DevOps Engineer\",\n  \"description\": \"Responsible for managing Kubernetes clusters and CI/CD pipelines.\",\n  \"location\": \"Remote (Global)\",\n  \"employment_type\": \"Remote\",\n  \"salary_range\": \"$130k - $160k\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/jobs",
              "host": ["{{BASE_URL}}"],
              "path": ["jobs"]
            }
          }
        },
        {
          "name": "Submit Application (Candidate)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"job_id\": \"PASTE_JOB_UUID_HERE\",\n  \"resume_url\": \"/uploads/resumes/my-resume.pdf\",\n  \"cover_letter\": \"I have 5 years of experience automating server deployments.\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/jobs/apply",
              "host": ["{{BASE_URL}}"],
              "path": ["jobs", "apply"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Control",
      "item": [
        {
          "name": "Get System Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/admin/users",
              "host": ["{{BASE_URL}}"],
              "path": ["admin", "users"]
            }
          }
        },
        {
          "name": "Get Audit logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{TOKEN}}"
              }
            ],
            "url": {
              "raw": "{{BASE_URL}}/admin/audit-logs",
              "host": ["{{BASE_URL}}"],
              "path": ["admin", "audit-logs"]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "BASE_URL",
      "value": "http://localhost:5000/api",
      "type": "string"
    },
    {
      "key": "TOKEN",
      "value": "",
      "type": "string"
    }
  ]
}
